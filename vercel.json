{
  "crons": [
    {
      "path": "/api/build-bill-cache",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/check-hearings",
      "schedule": "0 13 * * 1-5"
    },
    {
      "path": "/api/send-daily-report",
      "schedule": "30 13 * * 1-5"
    },
    {
      "path": "/api/send-eod-report",
      "schedule": "0 22 * * 1-5"
    },
    {
      "path": "/api/send-weekly-report",
      "schedule": "0 22 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdn.tailwindcss.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; connect-src 'self' https://*.supabase.co https://lims.dccouncil.gov; img-src 'self' data:; font-src 'self';"
        }
      ]
    }
  ]
}
